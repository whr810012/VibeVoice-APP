{
  "name": "vibevoice-desktop",
  "version": "0.1.1",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build --emptyOutDir false && electron-builder",
    "dist": "npm run build",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.vibevoice.desktop",
    "productName": "VibeVoice Desktop",
    "asar": true,
    "asarUnpack": [
      "backend/**",
      "python-win/**",
      "../vibevoice/**"
    ],
    "files": [
      "dist/**",
      "dist-electron/**",
      "electron/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "python-win",
        "to": "python-win",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../vibevoice",
        "to": "vibevoice",
        "filter": [
          "**/*"
        ]
      }
    ],
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "vue": "^3.3.4",
    "axios": "^1.4.0",
    "element-plus": "^2.3.8",
    "@element-plus/icons-vue": "^2.1.0",
    "wavesurfer.js": "^7.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^4.2.3",
    "electron": "^25.3.0",
    "electron-builder": "^24.4.0",
    "vite": "^4.4.4",
    "vite-plugin-electron": "^0.11.2",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vue-tsc": "^1.8.5",
    "typescript": "^5.1.6"
  }
}
